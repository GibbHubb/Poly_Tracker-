# Copy to .env and fill in real values. Never commit .env.

# Postgres connection string used by the API container.
DATABASE_URL=postgres://poly:poly@db:5432/poly_tracker

# Mapbox access token — required for satellite tiles + PDF export.
# Get one at https://account.mapbox.com/access-tokens/ (free tier is fine).
MAPBOX_TOKEN=pk.your_mapbox_token_here

# Ports
API_PORT=3001
WEB_PORT=5173

# Where uploaded photos are stored inside the api container (mounted volume).
PHOTO_STORAGE_PATH=/data/photos
