# Copy to .env and fill in real values. Never commit .env.
# `docker compose` reads this automatically.

# --- Database (single source of truth — DATABASE_URL must match the parts) ---
POSTGRES_USER=poly
POSTGRES_PASSWORD=poly
POSTGRES_DB=poly_tracker
DATABASE_URL=postgres://poly:poly@db:5432/poly_tracker

# --- Mapbox satellite basemap ---
# Used for the "Mapbox" imagery option + the Settings token check. The "Esri"
# imagery option works with no token. Free tier is fine.
# Get one at https://account.mapbox.com/access-tokens/ (public pk.… token).
MAPBOX_TOKEN=pk.your_mapbox_token_here

# --- Host-side ports (change if one is already in use) ---
# App is served at http://localhost:${NGINX_PORT}
NGINX_PORT=8080
API_PORT=3001
WEB_PORT=5173
DB_PORT=5432

# --- Photo uploads (path inside the api container / mounted volume) ---
PHOTO_STORAGE_PATH=/data/photos
